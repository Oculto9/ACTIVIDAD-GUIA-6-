<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>SwiftTrack - Sistema Inteligente de Envíos</title>
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        /* Navbar */
        .navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .logo i {
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 2rem;
        }

        .nav-links {
            display: flex;
            gap: 1rem;
        }

        .nav-btn {
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
        }

        .nav-btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }

        .nav-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .nav-btn-secondary {
            background: #f3f4f6;
            color: #4b5563;
        }

        .nav-btn-secondary:hover {
            background: #e5e7eb;
            transform: translateY(-2px);
        }

        /* Main Container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Cards */
        .card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
        }

        /* Form Styles */
        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #374151;
            font-size: 0.9rem;
        }

        .form-input, .form-select {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        /* Table Styles */
        .table-container {
            overflow-x: auto;
            border-radius: 16px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: #f9fafb;
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            color: #374151;
            border-bottom: 2px solid #e5e7eb;
        }

        td {
            padding: 1rem;
            border-bottom: 1px solid #f3f4f6;
        }

        tr:hover {
            background: #f9fafb;
        }

        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            display: inline-block;
        }

        .badge-pendiente { background: #fef3c7; color: #d97706; }
        .badge-en-ruta { background: #dbeafe; color: #2563eb; }
        .badge-entregado { background: #d1fae5; color: #059669; }

        /* Map Styles */
        .map-container {
            height: 400px;
            border-radius: 16px;
            overflow: hidden;
            margin-top: 1rem;
        }

        /* Grid Layout */
        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        /* Timeline */
        .timeline {
            position: relative;
            padding: 1rem 0;
        }

        .timeline-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin-bottom: 1rem;
        }

        .timeline-step {
            text-align: center;
            flex: 1;
            position: relative;
            z-index: 2;
        }

        .timeline-icon {
            width: 50px;
            height: 50px;
            background: white;
            border: 3px solid #e5e7eb;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            transition: all 0.3s ease;
        }

        .timeline-step.active .timeline-icon {
            border-color: #667eea;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            transform: scale(1.1);
        }

        .timeline-step.completed .timeline-icon {
            border-color: #10b981;
            background: #10b981;
            color: white;
        }

        .timeline-label {
            margin-top: 0.5rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: #6b7280;
        }

        .timeline-step.active .timeline-label {
            color: #667eea;
        }

        .timeline-progress {
            position: absolute;
            top: 25px;
            left: 0;
            right: 0;
            height: 3px;
            background: #e5e7eb;
            z-index: 1;
        }

        .timeline-progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transition: width 0.5s ease;
        }

        /* Alert */
        .alert {
            padding: 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-error {
            background: #fee2e2;
            color: #dc2626;
            border-left: 4px solid #dc2626;
        }

        .alert-success {
            background: #d1fae5;
            color: #059669;
            border-left: 4px solid #059669;
        }

        /* Section Visibility */
        .section {
            display: none;
        }

        .section.active {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Repartidores Grid */
        .repartidores-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .repartidor-card {
            background: #f9fafb;
            padding: 0.75rem;
            border-radius: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-container {
                flex-direction: column;
            }
            
            .grid-2 {
                grid-template-columns: 1fr;
            }
            
            .container {
                padding: 1rem;
            }
            
            .timeline-icon {
                width: 40px;
                height: 40px;
                font-size: 1.2rem;
            }
            
            .timeline-label {
                font-size: 0.7rem;
            }
        }

        /* Loading Animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 1.5rem;
            border-radius: 16px;
            text-align: center;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            font-size: 0.9rem;
            opacity: 0.9;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">
                <i class="fas fa-box"></i>
                <span>SwiftTrack</span>
            </div>
            <div class="nav-links">
                <button class="nav-btn nav-btn-secondary" onclick="showSection('tracking')">
                    <i class="fas fa-search"></i> Rastrear Paquete
                </button>
                <button class="nav-btn nav-btn-primary" onclick="showSection('admin')">
                    <i class="fas fa-chalkboard-user"></i> Panel Admin
                </button>
            </div>
        </div>
    </nav>

    <div class="container">
        <!-- Sección de Rastreo Público -->
        <div id="trackingSection" class="section active">
            <div class="card" style="max-width: 600px; margin: 0 auto;">
                <div style="text-align: center; margin-bottom: 2rem;">
                    <i class="fas fa-map-marked-alt" style="font-size: 3rem; background: linear-gradient(135deg, #667eea, #764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
                    <h2 style="margin-top: 1rem; color: #1f2937;">Rastrea tu Envío</h2>
                    <p style="color: #6b7280; margin-top: 0.5rem;">Ingresa tu número de guía para conocer el estado de tu paquete</p>
                </div>
                
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-hashtag"></i> Número de Guía
                    </label>
                    <input type="text" id="trackingGuia" class="form-input" placeholder="Ej: GUI-001-2024">
                </div>
                
                <button class="btn-primary" onclick="buscarPaquete()">
                    <i class="fas fa-search"></i> Buscar Paquete
                </button>
                
                <div id="trackingResult" style="margin-top: 2rem;"></div>
            </div>
        </div>

        <!-- Sección de Administración -->
        <div id="adminSection" class="section">
            <!-- Stats -->
            <div class="stats-grid" id="statsGrid"></div>
            
            <!-- Formulario y Mapa -->
            <div class="grid-2">
                <div class="card">
                    <h2 style="margin-bottom: 1.5rem; color: #1f2937;">
                        <i class="fas fa-plus-circle"></i> Registrar Nuevo Paquete
                    </h2>
                    <form id="packageForm">
                        <div class="form-group">
                            <label class="form-label">Remitente *</label>
                            <input type="text" id="remitente" class="form-input" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Destinatario *</label>
                            <input type="text" id="destinatario" class="form-input" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Dirección de Entrega *</label>
                            <input type="text" id="direccion" class="form-input" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Dimensiones *</label>
                            <input type="text" id="dimensiones" class="form-input" placeholder="Ej: 30x20x15 cm" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Peso *</label>
                            <input type="text" id="peso" class="form-input" placeholder="Ej: 2.5 kg" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Estado Inicial</label>
                            <select id="estadoInicial" class="form-select">
                                <option value="Pendiente">Pendiente</option>
                                <option value="En ruta">En ruta</option>
                                <option value="Entregado">Entregado</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-primary">
                            <i class="fas fa-save"></i> Registrar Paquete
                        </button>
                    </form>
                </div>
                
                <div class="card">
                    <h2 style="margin-bottom: 1.5rem; color: #1f2937;">
                        <i class="fas fa-truck"></i> Ubicación de Repartidores
                    </h2>
                    <div id="mapaRepartidores" class="map-container"></div>
                    <div id="repartidoresList" class="repartidores-grid"></div>
                </div>
            </div>
            
            <!-- Tabla de Paquetes -->
            <div class="card" style="margin-top: 1.5rem;">
                <h2 style="margin-bottom: 1.5rem; color: #1f2937;">
                    <i class="fas fa-list"></i> Lista de Paquetes
                </h2>
                <div class="table-container">
                    <table id="paquetesTable">
                        <thead>
                            <tr>
                                <th>N° Guía</th>
                                <th>Remitente</th>
                                <th>Destinatario</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="paquetesTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        // Datos de prueba
        let packages = [
            {
                id: 1,
                guia: "GUI-001-2024",
                remitente: "Juan Pérez",
                destinatario: "María García",
                direccion: "Calle Principal #123, Bogotá",
                dimensiones: "30x20x15 cm",
                peso: "2.5 kg",
                estado: "En ruta",
                ultimaUbicacion: { lat: 4.7110, lng: -74.0721 },
                fechaActualizacion: new Date("2024-01-15T10:30:00")
            },
            {
                id: 2,
                guia: "GUI-002-2024",
                remitente: "Carlos López",
                destinatario: "Ana Martínez",
                direccion: "Avenida Central #456, Medellín",
                dimensiones: "40x30x20 cm",
                peso: "5 kg",
                estado: "Entregado",
                ultimaUbicacion: { lat: 6.2442, lng: -75.5812 },
                fechaActualizacion: new Date("2024-01-14T15:45:00")
            },
            {
                id: 3,
                guia: "GUI-003-2024",
                remitente: "Laura Sánchez",
                destinatario: "Pedro Rodríguez",
                direccion: "Calle Secundaria #789, Cali",
                dimensiones: "25x18x10 cm",
                peso: "1 kg",
                estado: "Pendiente",
                ultimaUbicacion: { lat: 3.4516, lng: -76.5320 },
                fechaActualizacion: new Date("2024-01-16T08:00:00")
            }
        ];

        const repartidores = [
            { id: 1, nombre: "Carlos Ruiz", lat: 4.7110, lng: -74.0721, estado: "Activo", telefono: "3001234567" },
            { id: 2, nombre: "Ana Gómez", lat: 4.6989, lng: -74.0805, estado: "En entrega", telefono: "3002345678" },
            { id: 3, nombre: "Luis Fernández", lat: 4.7200, lng: -74.0650, estado: "Disponible", telefono: "3003456789" },
            { id: 4, nombre: "Martha Díaz", lat: 4.6900, lng: -74.0750, estado: "En ruta", telefono: "3004567890" },
            { id: 5, nombre: "Andrés Mendoza", lat: 4.7050, lng: -74.0600, estado: "Activo", telefono: "3005678901" }
        ];

        let mapRepartidores = null;
        let markers = [];

        // Mostrar/Ocultar secciones
        function showSection(section) {
            document.getElementById('trackingSection').classList.remove('active');
            document.getElementById('adminSection').classList.remove('active');
            
            if (section === 'tracking') {
                document.getElementById('trackingSection').classList.add('active');
            } else {
                document.getElementById('adminSection').classList.add('active');
                renderAdminPanel();
            }
        }

        // Renderizar Panel Admin
        function renderAdminPanel() {
            renderPackagesTable();
            updateStats();
            initMapaRepartidores();
        }

        // Actualizar estadísticas
        function updateStats() {
            const total = packages.length;
            const pendientes = packages.filter(p => p.estado === 'Pendiente').length;
            const enRuta = packages.filter(p => p.estado === 'En ruta').length;
            const entregados = packages.filter(p => p.estado === 'Entregado').length;
            
            document.getElementById('statsGrid').innerHTML = `
                <div class="stat-card">
                    <div class="stat-number">${total}</div>
                    <div class="stat-label">Total Paquetes</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${pendientes}</div>
                    <div class="stat-label">Pendientes</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${enRuta}</div>
                    <div class="stat-label">En Ruta</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">${entregados}</div>
                    <div class="stat-label">Entregados</div>
                </div>
            `;
        }

        // Renderizar tabla de paquetes
        function renderPackagesTable() {
            const tbody = document.getElementById('paquetesTableBody');
            tbody.innerHTML = packages.map(pkg => `
                <tr>
                    <td><strong>${pkg.guia}</strong></td>
                    <td>${pkg.remitente}</td>
                    <td>${pkg.destinatario}</td>
                    <td><span class="badge badge-${pkg.estado.toLowerCase().replace(' ', '-')}">${pkg.estado}</span></td>
                    <td>
                        <select onchange="cambiarEstado(${pkg.id}, this.value)" style="padding: 0.5rem; border-radius: 8px; border: 1px solid #e5e7eb;">
                            <option value="Pendiente" ${pkg.estado === 'Pendiente' ? 'selected' : ''}>Pendiente</option>
                            <option value="En ruta" ${pkg.estado === 'En ruta' ? 'selected' : ''}>En ruta</option>
                            <option value="Entregado" ${pkg.estado === 'Entregado' ? 'selected' : ''}>Entregado</option>
                        </select>
                    </td>
                </tr>
            `).join('');
        }

        // Cambiar estado de paquete
        function cambiarEstado(id, nuevoEstado) {
            const index = packages.findIndex(p => p.id === id);
            if (index !== -1) {
                packages[index].estado = nuevoEstado;
                packages[index].fechaActualizacion = new Date();
                renderPackagesTable();
                updateStats();
                showAlert('success', `Estado actualizado a "${nuevoEstado}"`);
            }
        }

        // Inicializar mapa de repartidores
        function initMapaRepartidores() {
            if (mapRepartidores) {
                mapRepartidores.remove();
            }
            
            mapRepartidores = L.map('mapaRepartidores').setView([4.7110, -74.0721], 12);
            
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(mapRepartidores);
            
            markers.forEach(marker => mapRepartidores.removeLayer(marker));
            markers = [];
            
            repartidores.forEach(repartidor => {
                const marker = L.marker([repartidor.lat, repartidor.lng]).addTo(mapRepartidores);
                marker.bindPopup(`
                    <div style="font-family: 'Inter', sans-serif;">
                        <strong>${repartidor.nombre}</strong><br>
                        <i class="fas fa-phone"></i> ${repartidor.telefono}<br>
                        <span class="badge badge-${repartidor.estado.toLowerCase().replace(' ', '-')}">${repartidor.estado}</span>
                    </div>
                `);
                markers.push(marker);
            });
            
            // Mostrar lista de repartidores
            document.getElementById('repartidoresList').innerHTML = repartidores.map(r => `
                <div class="repartidor-card">
                    <div>
                        <strong>${r.nombre}</strong><br>
                        <small>${r.telefono}</small>
                    </div>
                    <span class="badge badge-${r.estado.toLowerCase().replace(' ', '-')}">${r.estado}</span>
                </div>
            `).join('');
        }

        // Registrar nuevo paquete
        document.getElementById('packageForm').addEventListener('submit', (e) => {
            e.preventDefault();
            
            const nuevoPaquete = {
                id: Date.now(),
                guia: `GUI-${Date.now()}-${Math.floor(Math.random() * 1000)}`,
                remitente: document.getElementById('remitente').value,
                destinatario: document.getElementById('destinatario').value,
                direccion: document.getElementById('direccion').value,
                dimensiones: document.getElementById('dimensiones').value,
                peso: document.getElementById('peso').value,
                estado: document.getElementById('estadoInicial').value,
                ultimaUbicacion: { lat: 4.7110, lng: -74.0721 },
                fechaActualizacion: new Date()
            };
            
            packages.unshift(nuevoPaquete);
            renderPackagesTable();
            updateStats();
            
            e.target.reset();
            showAlert('success', `Paquete registrado exitosamente. Guía: ${nuevoPaquete.guia}`);
        });

        // Buscar paquete (rastreo)
        function buscarPaquete() {
            const guia = document.getElementById('trackingGuia').value.trim();
            const resultDiv = document.getElementById('trackingResult');
            
            if (!guia) {
                resultDiv.innerHTML = `
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-triangle"></i>
                        Por favor ingrese un número de guía
                    </div>
                `;
                return;
            }
            
            const paquete = packages.find(p => p.guia === guia);
            
            if (!paquete) {
                resultDiv.innerHTML = `
                    <div class="alert alert-error">
                        <i class="fas fa-search"></i>
                        No se encontró ningún paquete con la guía: ${guia}
                    </div>
                `;
                return;
            }
            
            const timelineSteps = ['Pendiente', 'En ruta', 'Entregado'];
            const currentStep = timelineSteps.indexOf(paquete.estado);
            const progressPercent = (currentStep / (timelineSteps.length - 1)) * 100;
            
            resultDiv.innerHTML = `
                <div class="card" style="margin-top: 1rem;">
                    <h3 style="color: #1f2937; margin-bottom: 1rem;">
                        <i class="fas fa-info-circle"></i> Detalles del Envío
                    </h3>
                    
                    <div class="timeline">
                        <div class="timeline-steps">
                            ${timelineSteps.map((step, index) => `
                                <div class="timeline-step ${index <= currentStep ? (index < currentStep ? 'completed' : 'active') : ''}">
                                    <div class="timeline-icon">
                                        ${step === 'Pendiente' ? '📦' : step === 'En ruta' ? '🚚' : '✅'}
                                    </div>
                                    <div class="timeline-label">${step}</div>
                                </div>
                            `).join('')}
                        </div>
                        <div class="timeline-progress">
                            <div class="timeline-progress-bar" style="width: ${progressPercent}%"></div>
                        </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 2rem;">
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">N° Guía</p>
                            <p style="font-weight: 600;">${paquete.guia}</p>
                        </div>
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">Remitente</p>
                            <p style="font-weight: 600;">${paquete.remitente}</p>
                        </div>
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">Destinatario</p>
                            <p style="font-weight: 600;">${paquete.destinatario}</p>
                        </div>
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">Dirección</p>
                            <p style="font-weight: 600;">${paquete.direccion}</p>
                        </div>
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">Dimensiones</p>
                            <p style="font-weight: 600;">${paquete.dimensiones}</p>
                        </div>
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">Peso</p>
                            <p style="font-weight: 600;">${paquete.peso}</p>
                        </div>
                        <div>
                            <p style="color: #6b7280; font-size: 0.8rem;">Última Actualización</p>
                            <p style="font-weight: 600;">${new Date(paquete.fechaActualizacion).toLocaleString('es-CO')}</p>
                        </div>
                    </div>
                    
                    <div id="trackingMap" style="height: 300px; margin-top: 1.5rem; border-radius: 12px; overflow: hidden;"></div>
                </div>
            `;
            
            // Inicializar mapa de rastreo
            const map = L.map('trackingMap').setView([paquete.ultimaUbicacion.lat, paquete.ultimaUbicacion.lng], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);
            
            L.marker([paquete.ultimaUbicacion.lat, paquete.ultimaUbicacion.lng])
                .addTo(map)
                .bindPopup(`
                    <div>
                        <strong>Ubicación del Paquete</strong><br>
                        ${paquete.direccion}
                    </div>
                `)
                .openPopup();
        }
        
        // Mostrar alerta
        function showAlert(type, message) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type}`;
            alertDiv.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i>
                ${message}
            `;
            
            document.querySelector('.container').insertBefore(alertDiv, document.querySelector('.container').firstChild);
            
            setTimeout(() => {
                alertDiv.remove();
            }, 3000);
        }
        
        // Inicializar
        renderAdminPanel();
        
        // Actualizar mapa cuando se muestra la sección admin
        setInterval(() => {
            if (document.getElementById('adminSection').classList.contains('active') && mapRepartidores) {
                mapRepartidores.invalidateSize();
            }
        }, 1000);
    </script>
</body>
</html>
